# LLM API 配置
API_URL=https://api.openai.com/v1
API_KEY=sk-your-api-key-here
API_MODEL=gpt-4o

# Minecraft 服务器配置
MC_HOST=localhost
MC_PORT=25565

# 机器人配置
BOT_NAME=LLM_Bot
BOT_ROLE=You are a friendly Minecraft builder. Your goal is to help players build structures, gather resources, and explore. You are curious and always offer to help.

# 决策间隔（毫秒）
DECISION_INTERVAL=3000
